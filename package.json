{
	"name": "shieldbyte",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"eval:phase1:export": "node --env-file=.env scripts/export-phase1-eval-sample.mjs",
		"eval:phase1:score": "node scripts/evaluate-phase1-accuracy.mjs",
		"train:phase1:model": "node scripts/train-phase1-ml-model.mjs",
		"verify:phase1:live": "node --env-file=.env scripts/verify-phase1-live.mjs"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@supabase/supabase-js": "^2.100.0",
		"cheerio": "^1.2.0",
		"groq-sdk": "^1.1.1",
		"rss-parser": "^3.13.0",
		"zod": "^4.3.6"
	}
}
